{
  "name": "muxboard",
  "version": "0.1.0",
  "description": "Stream Deck+ plugin surfacing cmux panes whose coding agents need attention, with CodexBar quota on the LCD strip.",
  "type": "module",
  "license": "MIT",
  "author": "mrshu",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "preview": "tsx scripts/preview.ts",
    "validate": "tsx scripts/validate.ts",
    "dev": "bash scripts/dev.sh",
    "icons": "tsx scripts/gen-icons.ts",
    "profile": "tsx scripts/gen-profile.ts"
  },
  "dependencies": {
    "@elgato/streamdeck": "^1.0.0"
  },
  "devDependencies": {
    "@elgato/cli": "^1.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "^22.0.0",
    "rollup": "^4.24.0",
    "tslib": "^2.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
